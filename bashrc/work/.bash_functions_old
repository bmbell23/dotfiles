}

function rul()
{
    # Run unified with smaller logdisk and specified state_sam logdisk size
    user_disks_dir="$USER""_disks";
    export UNIFIED_ENV="-l100000000 -o1000000 -T ""$user_disks_dir";
    gojanus;
    rm -rf disks/*;
    rm -rf /tmp/$USER/$user_disks_dir;
    mkdir disks;
