function repeat()
{
    # Repeat a command until it fails
    command=$@;
    exit=0
    count=0
    while [ $exit = 0 ]
    do
        $@
        exit=$?
        count=$((count+1))
        echo "Total executions: $count"
    done
    echo "Ran the command $@ a total of $count times"
}

function hudson_cleanup()
{
    # Clean up Hudson temporary files
    perl -e 'my $dir = "/tmp"; opendir( DIR, $dir ); my @files = readdir(DIR); closedir(DIR); my $num = scalar(@files); my $count = 0; foreach my $f ( @files ) { if ( $f =~ m/^hudson[0-9]/ ) { print "Removing $count / $num\n"; `sudo rm -rf $f`; } $count++; }'
}

function scanlog()
{
    # Search for patterns in log files
    to_find="$@"
    find_str="*/10.32.31.*/*/jt.log"
    grep "$to_find" "$find_str"
}

function remacs()
{
    # Open file in emacs read-only mode
    emacs "$1" --eval '(setq buffer-read-only t)'
}

function run_script()
{
    # Find and run a script with unified
    script=$1;
    shift
    gojanus
    SCRIPT_LOC=`find -type f -name $script | head -n 1`

    echo "Script found at $SCRIPT_LOC";
    echo "Running script $script...";

    perl $SCRIPT_LOC -start_unified $@
}

