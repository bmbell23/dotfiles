# Git management functions
function gbranch()
{
    # Create a new git branch and set upstream
    name=$1
    if [[ -z "$name" ]]; then
        echo "Must provide a branch name"
        return 1
    fi

    git branch $name
    git checkout $name
    git branch --set-upstream-to=origin $name
    git branch
}

function gdebranch()
{
    # Create a git branch with specific upstream
    name=$1
    if [[ -z "$name" ]]; then
        echo "Must provide a branch name"
        return 1
    fi

    git branch $name
    git checkout $name
    git branch --set-upstream-to=remotes/origin/de37821 $name
    git branch
}

# Unified environment functions
function setdual()
{
    # Setup session to run dual controller for emu (instance 2)
    export UNIFIED_ENV="-n2 -d1 -T ${USER}_disks -l1000000000"
}

function rus()
{
    # Run unified with smaller logdisk and dual rp
    user_disks_dir="$USER""_disks";
    export UNIFIED_ENV="-l100000000 -a2 -T ""$user_disks_dir";
    gojanus;
    rm -rf disks/*;
    rm -rf /tmp/$USER/$user_disks_dir;
    mkdir disks;
    ./unified
}

function ru()
{
    # Run unified with standard configuration
    user_disks_dir="$USER""_disks";
