function profile()
{
    # Profile an executable using valgrind
    target="$@"
    outdir=/home/$USER/work/general/profiling/callgrind/
    cg_file=$outdir/callgrind.out
    an_file=$outdir/annotated.txt
    mkdir -p $outdir

    echo "Profiling \"$target\" using valgrind. This takes a long time."
    valgrind --tool=callgrind --dump-instr=yes --collect-jumps=yes --callgrind-out-file=$cg_file $target 2>/dev/null
    callgrind_annotate --auto=yes $cg_file 2>/dev/null > $an_file
    echo "Profiling complete. Output in \"$outdir\""
    kcachegrind ${cg_file}
}

