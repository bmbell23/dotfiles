function rud()
{
    # Launch unified with specific enclosure configuration
    user_disks_dir="$USER""_disks";
    if [ $# != 1 ]; then
        return;
    fi

    if [ "$1" = "200nvx2" ]; then
        export UNIFIED_ENV="-l100000000 -o1000000 -y$1 -z2 -T ""$user_disks_dir";
    elif [ "$1" = "400nvx2" ]; then
        export UNIFIED_ENV="-l100000000 -o1000000 -y$1 -a2 -z1 -T ""$user_disks_dir";
    else
        export UNIFIED_ENV="-l100000000 -o1000000 -y$1 -T ""$user_disks_dir";
    fi
    gojanus;
    ./unified
}

function print_results()
{
    # Print build results with timestamps
    echo RESULTS
    echo $1 START TIME
    echo `date --rfc-3339=ns` END TIME
    find ../ddn-flash* -maxdepth 1 -type f -exec stat -c '%y %n' {} \; | sort -nr | awk 'NR>=1 && NR<=2 {print}'
    find unified -maxdepth 1 -type f -exec stat -c '%y %n' {} \; | sort -nr | awk 'NR==1,NR==1 {print}'
}
