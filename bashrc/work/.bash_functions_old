# Git utility functions
function getbranches()
{
    # Show branches that contain the given SHA
    sha=$1
    if [[ -z "${sha}" ]]; then
        echo "Provide a SHA to look up"
        return 1
    fi
    git branch -r --list 'origin/*' --contains $1
}

