
# File search and analysis functions
function tigb()
{
    # Tig blame on a file
    if [[ -z "$1" ]]; then
        echo "Provide filename"
        return 1
    fi
    tig blame `find . -type f -name $1`
}

function tigl()
{
    # Tig log on a file
    if [[ -z "$1" ]]; then
        echo "Provide filename"
        return 1
    fi
    tig log `find . -type f -name $1`
}

function ff()
{
    # Find a file by name
    if [[ -z "$1" ]]; then
        echo "Provide filename"
        return 1
    fi
    find . -name $1
}

function fastgrep()
{
    # Search for string excluding executable files
    if [[ -z "$1" ]]; then
        echo "Provide searchstring"
        return 1
    fi
    find . -type f ! -perm /111 -exec grep --exclude="*.obj" --exclude="*.lib" --exclude="*.zst" "$1" {} +
}

function pl()
{
    # Run pylint on a file
    if [[ -z "$1" ]]; then
        echo "Provide filename"
        return 1
    fi
    if [ ! -d test/monty ]; then
        echo "test/monty does not exist, are you in a valid git project?"
        return 1
    fi
    cd test/monty
    py3 -m pylint --rcfile .pylintrc `find . -type f -name $1`
    cd -
}

